# =============================
# IGR Protocol - Unified Env
# =============================

# --- Chain / RPC ---
# Prefer SEPOLIA_RPC_URL for deploy scripts.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
# Generic fallback used by recorder/governance readers.
RPC_URL=
RECORDER_RPC_URL=
GOV_RPC_URL=

# --- Wallet ---
# Primary key used by deploy/recorder scripts.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# CRE-specific alias (kept for compatibility)
CRE_ETH_PRIVATE_KEY=

# --- Contracts ---
MARKET_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
GOVERNANCE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CHAINLINK_PRICE_FEED_ADDRESS=0x0000000000000000000000000000000000000000
IGR_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_ADDRESS=
FORWARDER_ADDRESS=0x0000000000000000000000000000000000000000

# --- Model runtime ---
# sim | llm
MODEL_MODE=sim

# Endpoint override (optional)
MODEL_A_ENDPOINT=https://api.openai.com/v1/chat/completions
MODEL_B_ENDPOINT=https://api.anthropic.com/v1/messages
MODEL_A_ID=gpt-4o
MODEL_B_ID=claude-sonnet-4-20250514

# API keys
# You may set provider-native keys OR model-slot keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MODEL_A_API_KEY=
MODEL_B_API_KEY=

# --- Optional runtime toggles ---
ENABLE_CHAINLINK_FETCH=0
REPORT_METADATA_HEX=0x
