{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventSpec",
  "type": "object",
  "required": [
    "event_id",
    "market_id",
    "question",
    "rule_text",
    "market_end_time",
    "evaluation_time"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "market_id": {"type": "string"},
    "question": {"type": "string"},
    "rule_text": {"type": "string"},
    "resolution_source": {
      "type": "array",
      "items": {"type": "string"}
    },
    "market_end_time": {"type": "string"},
    "evaluation_time": {"type": "string"},
    "numeric_rule": {
      "type": "object",
      "required": ["operator", "threshold"],
      "properties": {
        "operator": {"type": "string", "enum": [">=", ">", "<=", "<"]},
        "threshold": {"type": "number"}
      }
    }
  }
}
