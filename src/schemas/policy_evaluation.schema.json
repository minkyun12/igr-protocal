{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyEvaluation",
  "type": "object",
  "required": ["event_id", "rules", "final_state", "reason_codes"],
  "properties": {
    "event_id": {"type": "string"},
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed", "value", "threshold"],
        "properties": {
          "name": {"type": "string"},
          "passed": {"type": "boolean"},
          "value": {},
          "threshold": {}
        }
      }
    },
    "final_state": {
      "type": "string",
      "enum": [
        "AUTO_RESOLVE_RECOMMENDED",
        "HOLD_FOR_REVIEW",
        "REJECTED_INSUFFICIENT_EVIDENCE"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
